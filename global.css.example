@tailwind base;
@tailwind components;
@tailwind utilities;
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap');

:root{
  --epi-blue:#0A2540;
  --epi-green:#1F7A4D;
  --epi-red:#D64545;
  --epi-navy:#081A2E;
  --epi-mist:#F4F7FB;
  --epi-slate:#4A5B70;
  --epi-white:#FFFFFF;
}

html, body {
  background: radial-gradient(circle at top right, rgba(15,56,96,0.12) 0%, rgba(15,56,96,0) 55%),
              linear-gradient(180deg, #F7F9FC 0%, #EFF3F8 45%, #E8EEF4 100%);
  background-attachment: fixed;
}

body {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  color: var(--epi-navy);
}

.card {
  background: var(--epi-white);
  border: 1px solid rgba(10,37,64,0.08);
  border-radius: 1rem;
  box-shadow: 0 12px 32px rgba(8,26,46,0.06);
  transition: box-shadow .2s ease, transform .2s ease;
}

.card:hover {
  box-shadow: 0 18px 42px rgba(8,26,46,0.10);
  transform: translateY(-2px);
}

.btn-primary {
  background: linear-gradient(135deg, var(--epi-blue), #123763);
  color: var(--epi-white);
  border: 1px solid #123763;
  transition: background-color .18s ease, transform .12s ease, box-shadow .18s ease;
}

.btn-primary:hover {
  background: linear-gradient(135deg, #123763, var(--epi-blue));
  transform: translateY(-1px);
}

.btn-primary:active {
  background: #0F3055;
  transform: translateY(0);
}

.btn-primary:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px rgba(15,56,96,0.28);
}

.btn-primary:disabled {
  opacity: .6;
  cursor: not-allowed;
  transform: none;
}

.btn-secondary {
  background: linear-gradient(135deg, var(--epi-green), #1A6A42);
  color: var(--epi-white);
  border: 1px solid #1A6A42;
  transition: background-color .18s ease, transform .12s ease, box-shadow .18s ease;
}

.btn-secondary:hover {
  background: linear-gradient(135deg, #1A6A42, var(--epi-green));
  transform: translateY(-1px);
}

.btn-secondary:active {
  background: #175A38;
  transform: translateY(0);
}

.btn-secondary:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px rgba(31,122,77,0.25);
}

.btn-secondary:disabled {
  opacity: .6;
  cursor: not-allowed;
  transform: none;
}

.tab-active {
  color: var(--epi-blue);
  border-bottom: 2px solid var(--epi-blue);
}

.chip {
  border: 1px solid rgba(10,37,64,0.18);
  color: var(--epi-blue);
  border-radius: 9999px;
  padding: 2px 10px;
  font-size: 12px;
  background: rgba(10,37,64,0.05);
}

/* App surfaces: header/footer stay white with subtle elevation */
.app-header, .app-footer {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(8px);
  box-shadow: 0 8px 24px rgba(8,26,46,0.08);
  transition: box-shadow .2s ease, transform .2s ease;
}

.app-header:hover, .app-footer:hover {
  box-shadow: 0 14px 38px rgba(8,26,46,0.12);
}

/* Card title accent: animated blue-green underline */
.card-title{
  position: relative;
  padding-top: 12px;
}

.card-title::before{
  content:"";
  position: absolute;
  top: 0;
  left: 0;
  height: 4px;
  width: 88px;
  background: linear-gradient(90deg, var(--epi-blue), var(--epi-green), var(--epi-blue));
  background-size: 200% 100%;
  border-radius: 9999px;
  animation: cardbar-flow 3s linear infinite;
}

@keyframes cardbar-flow{
  0%{ background-position: 0% 0; }
  100%{ background-position: 200% 0; }
}
