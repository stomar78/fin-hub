        'fade-in-up': {
          '0%': { opacity: '0', transform: 'translateY(32px)' },
          '60%': { opacity: '1', transform: 'translateY(6px)' },
          '100%': { opacity: '1', transform: 'translateY(0)' }
        }
      },
      animation: {
        'fade-in-up': 'fade-in-up 420ms ease-out forwards'
      }
    },
  },
  plugins: [],
